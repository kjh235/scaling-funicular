  "policies": [
    {
      "id": "us-hos-holiday-exemption",
      "name": "HOS Holiday Hours Exemption",
      "category": "labor_rule",
      "status": "official",
      "tags": ["hours_of_service", "driver", "exemption"],
      "time_definition": {
        "recurrence": {
          "rrule": "FREQ=YEARLY;BYMONTH=11;BYDAY=4TH",
          "timezone": "America/Chicago"
        }
      },
      "applicability": {
        "roles": ["driver"],
        "modes": ["truck"],
        "vehicle_classes": ["class_7", "class_8"]
      },
      "rules": [
        {
          "kind": "hours_of_service",
          "constraints": {
            "max_driving_hours": 11,
            "max_on_duty_hours": 14,
            "exemption": "holiday_short_haul"
          }
        }
      ]
    }
  ],

  "impacts": [
    {
      "match": { "event_id": "us-new-years-day" },
      "operational_impact": {
        "impact_level": "full",
        "affected_operations": ["freight_pickup", "freight_delivery", "customs_clearance", "port_operations"],
        "notes": "Federal holiday — most freight operations closed. Plan for day-before and day-after surge."
      },
      "impact_schedule": {
        "timezone": "America/New_York",
        "operations": [
          {
            "operation": "freight_delivery",
            "rules": [
              {
                "when": { "date_ref": "observed", "offset_days": 0 },
                "effect": { "status": "closed", "severity": "full" },
                "reason": "Federal holiday"
              },
              {
                "when": { "date_ref": "observed", "offset_days": -1 },
                "if": { "weekday_in": ["MO", "TU", "WE", "TH", "FR"] },
                "effect": { "status": "partial", "severity": "partial" },
                "reason": "New Year's Eve — reduced capacity, early close expected"
              }
            ]
          },
          {
            "operation": "customs_clearance",
            "rules": [
              {
                "when": { "date_ref": "observed", "offset_days": 0 },
                "effect": { "status": "closed", "severity": "full" },
                "reason": "CBP closed on federal holidays"
              }
            ]
          },
          {
            "operation": "port_operations",
